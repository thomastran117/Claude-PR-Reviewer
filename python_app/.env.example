# GitHub App Configuration
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nyour-private-key-here\n-----END RSA PRIVATE KEY-----
GITHUB_INSTALLATION_ID=your-installation-id

# API Authentication
ALLOWED_API_KEYS={"your-secret-key":"username"}

# Server Configuration
PORT=3000

# Note: ANTHROPIC_API_KEY is not stored here — clients supply their own key per request